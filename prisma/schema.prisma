generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique @db.VarChar(50)
  address         String   @unique @db.VarChar(42)
  pfp             String?  @db.VarChar(255)
  worldIdVerified Boolean  @default(false)
  worldIdLevel    String?  @db.VarChar(10) // "orb" or "device"
  totalPoints     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdPools    Pool[]    @relation("Creator")
  arbitratedPools Pool[]    @relation("Arbiter")
  jousts          Joust[]
  notifications   Notification[]
  votesCast       HonorVote[]  @relation("Voter")
  votesReceived   HonorVote[]  @relation("ArbiterHonor")
  honorScore      HonorScore?  @relation("UserHonorScore")
  worldIdVerifications WorldIdVerification[]

  @@index([address])
}

model Pool {
  id                 String    @id @default(uuid(7)) @db.Uuid
  contractId         BigInt?
  title              String    @db.VarChar(200)
  description        String?   @db.VarChar(2000)
  image              String?   @db.VarChar(255)
  creatorId          Int
  creator            User      @relation("Creator", fields: [creatorId], references: [id])
  arbiterId          Int?
  arbiter            User?     @relation("Arbiter", fields: [arbiterId], references: [id])
  arbiterAddress     String    @db.VarChar(42)
  arbiterAccepted    Boolean   @default(false)
  arbiterFee         Int       @db.SmallInt
  collateral         String    @db.VarChar(42)
  minJoustAmount     BigInt
  totalAmountJousted BigInt    @default(0)
  supportedJoustTypes Int      @db.SmallInt @default(2)
  winningJoustType   Int       @default(0) @db.SmallInt
  state              PoolState @default(PENDING_ARBITER)
  endTime            DateTime
  contractEndTime    Int       @default(0)
  deployedAt         DateTime?
  closedAt           DateTime?
  settledAt          DateTime?
  refundedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jousts        Joust[]
  options       PoolOption[]
  notifications Notification[]
  honorVotes    HonorVote[]

  @@unique([contractId])
  @@index([contractId])
  @@index([creatorId])
  @@index([arbiterId])
  @@index([arbiterAddress])
  @@index([state])
  @@index([endTime])
  @@index([state, endTime])
}

enum PoolState {
  PENDING_ARBITER
  ACTIVE
  CLOSED
  SETTLED
  REFUNDED
}

model PoolOption {
  id         Int    @id @default(autoincrement())
  poolId     String @db.Uuid
  pool       Pool   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  joustType  Int    @db.SmallInt
  label      String @db.VarChar(400)
  orderIndex Int    @db.SmallInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([poolId, joustType])
  @@unique([poolId, orderIndex])
  @@index([poolId])
}

model Joust {
  id        Int     @id @default(autoincrement())
  userId    Int
  poolId    String  @db.Uuid
  user      User    @relation(fields: [userId], references: [id])
  pool      Pool    @relation(fields: [poolId], references: [id], onDelete: Cascade)
  joustType Int     @db.SmallInt
  amount    BigInt
  isWinner  Boolean @default(false)
  txHash    String? @db.VarChar(66)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([poolId])
  @@index([joustType])
}

model Notification {
  id     Int              @id @default(autoincrement())
  userId Int
  user   User             @relation(fields: [userId], references: [id])
  type   NotificationType
  title  String           @db.VarChar(255)
  body   String?          @db.VarChar(3000)
  poolId String?          @db.Uuid
  pool   Pool?            @relation(fields: [poolId], references: [id], onDelete: Cascade)
  read   Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, read])
  @@index([poolId])
}

enum NotificationType {
  ARBITER_INVITE
  ARBITER_ACCEPTED
  POOL_SETTLED
  JOUST_CREATED
  POOL_REFUNDED
  PAYOUT_READY
}

model HonorVote {
  id          Int           @id @default(autoincrement())
  voterId     Int
  arbiterId   Int
  poolId      String        @db.Uuid
  voteType    HonorVoteType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voter   User @relation("Voter", fields: [voterId], references: [id])
  arbiter User @relation("ArbiterHonor", fields: [arbiterId], references: [id])
  pool    Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([voterId, arbiterId, poolId])
  @@index([arbiterId])
  @@index([voterId])
}

enum HonorVoteType {
  UPVOTE
  DOWNVOTE
}

model HonorScore {
  arbiterId      Int   @id
  totalUpvotes   Int   @default(0)
  totalDownvotes Int   @default(0)
  score          Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  arbiter User @relation("UserHonorScore", fields: [arbiterId], references: [id])

  @@index([score])
}

model WorldIdVerification {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id])
  action            String   // "verify-identity", "create-pool", "honor-vote"
  nullifierHash     String   @unique @db.VarChar(68)
  verificationLevel String   // "orb" or "device"

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action, nullifierHash])
}
