{
  "name": "joust-world-miniapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check": "tsc --noEmit && eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "pnpm exec prisma generate",
    "db:generate": "pnpm exec prisma generate",
    "db:format": "pnpm exec prisma format",
    "db:migrate": "pnpm exec prisma migrate dev --create-only",
    "db:migrateFinalize": "pnpm exec prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/client": "^6.14.0",
    "@tanstack/react-query": "^5.75.0",
    "@worldcoin/idkit": "^4.0.11",
    "@worldcoin/idkit-core": "^4.1.0",
    "@worldcoin/minikit-js": "^2.0.2",
    "@worldcoin/minikit-react": "^1.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "iron-session": "^8.0.4",
    "next": "15.5.14",
    "motion": "^12.38.0",
    "ogl": "^1.0.11",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.1.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.24.0",
    "wagmi": "^3.6.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.14.0",
    "eruda": "^3.4.3",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0"
  }
}
